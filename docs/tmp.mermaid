graph TD
    %% External Entities
    Client([Client Application])
    PeerAPI([Peer Node: API])
    PeerRep([Peer Node: Replication])

    %% Node Boundary
    subgraph ConvergeKV Node
        %% Frontend / Routing
        API[API Layer <br/> gRPC Handler]
        Coord[Coordinator]
        Fwd[Forwarder]
        
        %% Core Data & Logic
        CoreNode[Node <br/> Core State Manager]
        CRDT[CRDT Engine <br/> AWLWW Map]
        HLC[Hybrid Logical Clock]
        Storage[(Storage Layer <br/> BadgerDB)]
        
        %% Topology & Sync
        Ring[Consistent Hash Ring]
        Gossip[Gossip Layer <br/> Memberlist]
        Merkle[Merkle Tree]
        Rep[Replication Layer <br/> Anti-Entropy]
    end

    %% Client Interactions
    Client -->|Put / Get / Delete| API
    
    %% Coordinator Flow
    API --> Coord
    Coord -->|Local R/W| CoreNode
    Coord -->|Lookup Primary/Replicas| Ring
    Coord -->|Forward to Peers| Fwd
    Fwd -.->|gRPC ForwardPut| PeerAPI

    %% Core Node Flow
    CoreNode -->|Generate/Update Time| HLC
    CoreNode -->|Merge logic / Conflict rules| CRDT
    CoreNode -->|Update Partition Hashes| Merkle
    CoreNode -->|Persist Field Entries| Storage

    %% Topology Flow
    Gossip -->|Membership Changes| Ring
    
    %% Replication Flow
    Rep -->|Discover Peers| Gossip
    Rep -->|Find Shared Data| Ring
    Rep -->|Check for Divergence| Merkle
    Rep -->|Apply Missing Deltas| CoreNode
    Rep -.->|Phase 1 & 2 Sync| PeerRep